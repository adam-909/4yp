    tickers=ALL_TICKERS,
    data_loader=pull_equities_sample_data,
    threshold=selected_threshold,
)
# Create graph from the adjacency matrix.
G = nx.from_pandas_adjacency(adjacency_matrix)

# Compute Louvain communities with resolution=1.
communities = louvain_communities(G, resolution=1)
community_assignments = {}
for comm_id, community in enumerate(communities):
    for node in community:
        community_assignments[node] = comm_id

# Use the nodes as they are in G.
labels = {node: node for node in G.nodes()}
predicted_labels = [community_assignments.get(node, -1) for node in G.nodes()]
node_sector_colors = [sector_colors.get(BBG_SECTORS.get(node, "Other"), "gray") for node in G.nodes()]

# Use Kamada-Kawai layout for positioning.
pos = nx.kamada_kawai_layout(G)
# Normalize positions to fill the plot area (from -2 to 2 on both axes).
x_vals = [p[0] for p in pos.values()]
y_vals = [p[1] for p in pos.values()]
x_min, x_max = min(x_vals), max(x_vals)
y_min, y_max = min(y_vals), max(y_vals)
for node in pos:
    pos[node] = (
        (pos[node][0] - x_min) / (x_max - x_min) * 4 - 2,
        (pos[node][1] - y_min) / (y_max - y_min) * 4 - 2,
    )

# Create side-by-side plots.
fig, axes = plt.subplots(1, 2, figsize=(12, 8))

# ----- Left Plot: Nodes colored by Sector -----
nx.draw_networkx_nodes(
    G,
    pos=pos,
    nodelist=list(G.nodes()),
    node_size=400,
    node_color=node_sector_colors,
    edgecolors="black",
    alpha=0.9,
    ax=axes[0],
)
